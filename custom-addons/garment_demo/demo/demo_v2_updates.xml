        </function>
        <function model="garment.order" name="write">
            <value eval="[ref('order_tshirt_eu')]"/>
            <value eval="{'state': 'cutting'}"/>
        </function>
        <function model="garment.order" name="write">
            <value eval="[ref('order_v2_jp_done')]"/>
            <value eval="{'state': 'done'}"/>
        </function>
        <function model="garment.order" name="write">
            <value eval="[ref('order_v2_eu_shipped')]"/>
            <value eval="{'state': 'shipped'}"/>
        </function>
    </data>
</odoo>
