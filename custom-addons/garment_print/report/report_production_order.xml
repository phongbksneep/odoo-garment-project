<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_production_order" model="ir.actions.report">
        <field name="name">In Lệnh Sản Xuất</field>
        <field name="model">garment.production.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">garment_print.report_production_order_document</field>
        <field name="report_file">garment_print.report_production_order_document</field>
        <field name="binding_model_id" ref="garment_production.model_garment_production_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'LenhSX_%s' % object.name</field>
    </record>

    <template id="report_production_order_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mb-2">LỆNH SẢN XUẤT</h2>
                        <h4 class="text-center mb-4"><t t-out="doc.name"/></h4>
                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr><td><strong>Đơn hàng:</strong></td><td><t t-out="doc.garment_order_id.name"/></td></tr>
                                    <tr><td><strong>Khách hàng:</strong></td><td><t t-out="doc.customer_id.name or '-'"/></td></tr>
                                    <tr><td><strong>Mã hàng:</strong></td><td><t t-out="doc.style_id.display_name or '-'"/></td></tr>
                                    <tr><td><strong>Chuyền may:</strong></td><td><t t-out="doc.sewing_line_id.name or '-'"/></td></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr><td><strong>SL kế hoạch:</strong></td><td><t t-out="'{:,}'.format(doc.planned_qty)"/> sp</td></tr>
                                    <tr><td><strong>Bắt đầu:</strong></td><td><t t-out="doc.start_date or '-'"/></td></tr>
                                    <tr><td><strong>Kết thúc dự kiến:</strong></td><td><t t-out="doc.end_date or '-'"/></td></tr>
                                    <tr><td><strong>SAM:</strong></td><td><t t-out="doc.sam or '-'"/></td></tr>
                                </table>
                            </div>
                        </div>
                        <h5>Chi tiết size/màu (theo đơn hàng)</h5>
                        <table class="table table-sm table-bordered mb-4">
                            <thead>
                                <tr class="table-light">
                                    <th>Màu</th><th>Size</th>
                                    <th class="text-end">Số Lượng</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.garment_order_id.line_ids" t-as="line">
                                    <td><t t-out="line.color_id.name"/></td>
                                    <td><t t-out="line.size_id.name"/></td>
                                    <td class="text-end"><t t-out="'{:,}'.format(line.quantity)"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="row mt-5">
                            <div class="col-4 text-center"><strong>Người Lập</strong><br/><br/><br/>(Ký, họ tên)</div>
                            <div class="col-4 text-center"><strong>Chuyền Trưởng</strong><br/><br/><br/>(Ký, họ tên)</div>
                            <div class="col-4 text-center"><strong>Quản Đốc</strong><br/><br/><br/>(Ký, họ tên)</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
